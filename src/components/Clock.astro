---
<div class="fixed bottom-10 left-12 text-left text-white/90 drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)] select-none pointer-events-none z-10">
  <div id="time" class="text-[3.5rem] font-bold tracking-[-1px] leading-none mb-1"></div>
  <div id="date" class="text-base font-normal opacity-80"></div>
</div>

<script>
  function updateClock() {
    const now = new Date();
    const timeOptions: Intl.DateTimeFormatOptions = { hour: "numeric", minute: "2-digit", hour12: true };
    const timeString = now.toLocaleTimeString([], timeOptions);
    const dateOptions: Intl.DateTimeFormatOptions = { weekday: "long", month: "long", day: "numeric" };
    const dateString = now.toLocaleDateString([], dateOptions);

    const timeEl = document.getElementById("time");
    const dateEl = document.getElementById("date");

    if (timeEl && dateEl) {
      timeEl.textContent = timeString;
      dateEl.textContent = dateString;
    }
  }

  setInterval(updateClock, 1000);
  updateClock();
</script>
