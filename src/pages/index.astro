---
import '../styles/global.css';
import Wallpaper from '../components/Wallpaper.astro';
import SocialControls from '../components/SocialControls.astro';
import TodoList from '../components/TodoList.astro';
import Clock from '../components/Clock.astro';
import PlaybackControls from '../components/PlaybackControls.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bocchi</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
  </head>
  <body class="font-[Space_Mono,monospace] m-0 p-0 box-border text-white overflow-hidden">
    <Wallpaper />

    <main>
      <SocialControls />
      <TodoList />
      <Clock />
      <PlaybackControls />
    </main>
  </body>
</html>
